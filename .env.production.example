# =============================================================================
# Production .env for PythonAnywhere
# Copy to .env on the server:  cp .env.production.example .env
# Replace YOURUSERNAME and all placeholder values.
# =============================================================================

# Django
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=change-me-generate-a-long-random-secret-key
DEBUG=False

# Your PythonAnywhere domain (add custom domain too if you have one)
ALLOWED_HOSTS=YOURUSERNAME.pythonanywhere.com
SITE_URL=https://YOURUSERNAME.pythonanywhere.com
SITE_NAME=Arba Minch Tourist Hotel

# CSRF (must match your HTTPS URL)
CSRF_TRUSTED_ORIGINS=https://YOURUSERNAME.pythonanywhere.com

# SSL — PythonAnywhere handles HTTPS at the proxy; keep these as shown
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# -----------------------------------------------------------------------------
# Database — Option A: MySQL (recommended on PythonAnywhere)
# Create database in PythonAnywhere Databases tab first.
# -----------------------------------------------------------------------------
DB_ENGINE=django.db.backends.mysql
DB_NAME=YOURUSERNAME$amth_hotel
DB_USER=YOURUSERNAME
DB_PASSWORD=your-mysql-password
DB_HOST=YOURUSERNAME.mysql.pythonanywhere-services.com
DB_PORT=3306

# -----------------------------------------------------------------------------
# Database — Option B: SQLite (simplest; fine for demos / low traffic)
# Uncomment below and comment out MySQL block above.
# -----------------------------------------------------------------------------
# DB_ENGINE=
# (leave DB_ENGINE empty to use SQLite at db.sqlite3)

# Email (optional — console backend used if not configured)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@arbaminchhotel.com

# Google Maps (optional)
GOOGLE_MAPS_API_KEY=
